@model ShopManagement.Models.ChangePasswordViewModel

@{
    ViewBag.Title = "Doi mat khau";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="card form-card">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-3">Doi mat khau</h1>
                <p class="text-muted">Su dung mat khau co it nhat 6 ky tu.</p>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="mb-3">
                        @Html.LabelFor(model => model.CurrentPassword, new { @class = "form-label" })
                        @Html.PasswordFor(model => model.CurrentPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.CurrentPassword, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.NewPassword, new { @class = "form-label" })
                        @Html.PasswordFor(model => model.NewPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.NewPassword, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(model => model.ConfirmNewPassword, new { @class = "form-label" })
                        @Html.PasswordFor(model => model.ConfirmNewPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.ConfirmNewPassword, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-dark">Cap nhat mat khau</button>
                        @Html.ActionLink("Quay lai ho so", "Profile", "Account", null, new { @class = "btn btn-outline-secondary" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}