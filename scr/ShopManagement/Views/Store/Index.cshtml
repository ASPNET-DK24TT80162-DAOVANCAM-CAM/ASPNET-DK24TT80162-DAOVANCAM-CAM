@model ShopManagement.Models.StoreHomeViewModel

@{
    ViewBag.Title = "Cửa hàng";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<main>
    <section class="store-hero p-4 p-lg-5 mb-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <p class="text-uppercase text-muted mb-2">Bộ sưu tập 2026</p>
                <h1 class="display-6 fw-semibold mb-3">Giày cho nhịp sống thành phố, đi làm và đi chơi cuối tuần.</h1>
                <p class="lead text-muted mb-4">Khám phá giày nam nữ với thiết kế linh hoạt, chất liệu tốt và dễ đi mỗi ngày.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a href="@Url.Action("Products", "Store", new { gender = "Men" })" class="btn btn-dark">Mua giày nam</a>
                    <a href="@Url.Action("Products", "Store", new { gender = "Women" })" class="btn btn-outline-dark">Mua giày nữ</a>
                    <a href="@Url.Action("Products", "Store")" class="btn btn-outline-secondary">Tất cả sản phẩm</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="store-highlight p-4 rounded-4">
                    <h2 class="h5 mb-3">Truy cập nhanh</h2>
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Index", "Wishlist")" class="btn btn-light text-start">Yêu thích</a>
                        <a href="@Url.Action("Index", "Cart")" class="btn btn-light text-start">Giỏ hàng</a>
                        <a href="@Url.Action("Index", "Orders")" class="btn btn-light text-start">Đơn hàng</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">Sản phẩm mới</h2>
            <a href="@Url.Action("Products", "Store")" class="btn btn-sm btn-outline-dark">Xem tất cả</a>
        </div>
        <div class="row g-3">
            @foreach (var item in Model.NewArrivals)
            {
                <div class="col-6 col-lg-3">
                    <a href="@Url.Action("Details", "Store", new { slug = item.Slug })" class="text-decoration-none text-dark">
                        <div class="card product-card h-100 border-0">
                            <img src="@item.ThumbnailImage" class="card-img-top product-img" alt="@item.Name" />
                            <div class="card-body">
                                <p class="small text-muted mb-1">@item.Brand.Name</p>
                                <h3 class="h6 mb-2">@item.Name</h3>
                                <p class="mb-0 fw-semibold">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VNĐ</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>

    <section class="row g-4">
        <div class="col-lg-6">
            <h2 class="h4 mb-3">Gợi ý cho nam</h2>
            <div class="d-grid gap-3">
                @foreach (var item in Model.FeaturedMen)
                {
                    <a href="@Url.Action("Details", "Store", new { slug = item.Slug })" class="card product-inline border-0 text-decoration-none text-dark">
                        <div class="card-body d-flex gap-3 align-items-center">
                            <img src="@item.ThumbnailImage" class="rounded-3 product-inline-img" alt="@item.Name" />
                            <div>
                                <p class="small text-muted mb-1">@item.Category.Name</p>
                                <h3 class="h6 mb-1">@item.Name</h3>
                                <p class="mb-0 fw-semibold">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VNĐ</p>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
        <div class="col-lg-6">
            <h2 class="h4 mb-3">Gợi ý cho nữ</h2>
            <div class="d-grid gap-3">
                @foreach (var item in Model.FeaturedWomen)
                {
                    <a href="@Url.Action("Details", "Store", new { slug = item.Slug })" class="card product-inline border-0 text-decoration-none text-dark">
                        <div class="card-body d-flex gap-3 align-items-center">
                            <img src="@item.ThumbnailImage" class="rounded-3 product-inline-img" alt="@item.Name" />
                            <div>
                                <p class="small text-muted mb-1">@item.Category.Name</p>
                                <h3 class="h6 mb-1">@item.Name</h3>
                                <p class="mb-0 fw-semibold">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VNĐ</p>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
</main>
