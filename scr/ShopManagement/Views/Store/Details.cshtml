@model ShopManagement.Models.ProductDetailsViewModel
@using System
@using System.Linq

@{
    ViewBag.Title = Model.Product.Name;
    Layout = "~/Views/Shared/_ShopLayout.cshtml";

    var galleryImages = Model.Product.Images
        .OrderBy(item => item.SortOrder)
        .Select(item => Tuple.Create(item.ImageUrl, string.IsNullOrWhiteSpace(item.AltText) ? Model.Product.Name : item.AltText))
        .ToList();

    if (!galleryImages.Any() && !string.IsNullOrWhiteSpace(Model.Product.ThumbnailImage))
    {
        galleryImages.Add(Tuple.Create(Model.Product.ThumbnailImage, Model.Product.Name));
    }

    var mainImage = galleryImages.Any() ? galleryImages.First().Item1 : Model.Product.ThumbnailImage;
    var selectedVariant = Model.SelectedVariant;
    var selectedPrice = selectedVariant != null ? selectedVariant.Price : (Model.Product.SalePrice ?? Model.Product.BasePrice);
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 product-card product-gallery-shell p-2">
            <img id="mainProductImage" src="@mainImage" class="img-fluid rounded-4 product-main-image" alt="@Model.Product.Name" />
        </div>
        @if (galleryImages.Any())
        {
            <div class="row g-2 mt-2 product-thumb-grid">
                @foreach (var image in galleryImages)
                {
                    <div class="col-3 col-md-2">
                        <button type="button" class="product-thumb-btn" data-image-url="@image.Item1" data-image-alt="@image.Item2">
                            <img src="@image.Item1" class="img-fluid rounded-3" alt="@image.Item2" />
                        </button>
                    </div>
                }
            </div>
        }
    </div>
    <div class="col-lg-6">
        <p class="text-muted mb-1">@Model.Product.Brand.Name • @Model.Product.Category.Name</p>
        <h1 class="h3 mb-3">@Model.Product.Name</h1>
        <p class="h4 mb-3" id="productPrice">@selectedPrice.ToString("N0") VNĐ</p>
        <p class="text-muted">@Model.Product.Description</p>

        <div class="alert alert-light border" id="variantStatus">
            @if (selectedVariant != null)
            {
                <text>Đã chọn: @selectedVariant.Color.Name / Size @selectedVariant.Size.Name - Tồn kho: @selectedVariant.StockQuantity</text>
            }
            else
            {
                <text>Sản phẩm hiện chưa có biến thể khả dụng.</text>
            }
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3" id="variantSelector">
            @foreach (var variant in Model.Variants)
            {
                var activeClass = selectedVariant != null && selectedVariant.Id == variant.Id ? "is-active" : string.Empty;
                <button type="button"
                        class="btn btn-sm btn-outline-dark variant-btn @activeClass"
                        data-variant-id="@variant.Id"
                        data-variant-stock="@variant.StockQuantity"
                        data-variant-price="@variant.Price.ToString("0.##")"
                        data-variant-label="@variant.Color.Name / @variant.Size.Name">
                    @variant.Color.Name / @variant.Size.Name
                </button>
            }
        </div>

        @if (selectedVariant != null)
        {
            using (Html.BeginForm("Add", "Cart", FormMethod.Post, new { @class = "d-flex gap-2 align-items-end mb-2", id = "addToCartForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("productVariantId", selectedVariant.Id, new { id = "cartVariantId" })
                @Html.Hidden("returnUrl", Request.RawUrl)
                <div>
                    <label class="form-label">Số lượng</label>
                    <input type="number" class="form-control" id="orderQuantity" name="quantity" min="1" max="@Math.Max(selectedVariant.StockQuantity, 1)" value="1" />
                </div>
                <button type="submit" class="btn btn-dark" id="addToCartBtn" @(selectedVariant.StockQuantity <= 0 ? "disabled" : "")>Thêm vào giỏ</button>
            }

            using (Html.BeginForm("BuyNow", "Cart", FormMethod.Post, new { @class = "d-flex gap-2 align-items-end mb-3", id = "buyNowForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("productVariantId", selectedVariant.Id, new { id = "buyNowVariantId" })
                @Html.Hidden("quantity", 1, new { id = "buyNowQuantity" })
                <button type="submit" class="btn btn-accent" id="buyNowBtn" @(selectedVariant.StockQuantity <= 0 ? "disabled" : "")>Mua ngay</button>
            }
        }
        else
        {
            <button type="button" class="btn btn-dark" disabled>Hết hàng</button>
        }

        @using (Html.BeginForm("Add", "Wishlist", FormMethod.Post, new { @class = "d-inline-block" }))
        {
            @Html.AntiForgeryToken()
            @Html.Hidden("productId", Model.Product.Id)
            @Html.Hidden("returnUrl", Request.RawUrl)
            <button type="submit" class="btn btn-outline-secondary">Thêm vào yêu thích</button>
        }
    </div>
</div>

<section class="mt-5">
    <h2 class="h4 mb-3">Sản phẩm liên quan</h2>
    <div class="row g-3">
        @foreach (var item in Model.RelatedProducts)
        {
            <div class="col-sm-6 col-lg-3">
                <a href="@Url.Action("Details", "Store", new { slug = item.Slug })" class="card product-card border-0 text-decoration-none text-dark h-100">
                    <img src="@item.ThumbnailImage" class="card-img-top product-img" alt="@item.Name" />
                    <div class="card-body">
                        <p class="small text-muted mb-1">@item.Brand.Name • @item.Category.Name</p>
                        <h3 class="h6">@item.Name</h3>
                        <p class="mb-0 fw-semibold">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VNĐ</p>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

@section scripts {
<script>
    (function () {
        var detailsSlug = '@Model.Product.Slug';
        var endpoint = '@Url.Action("VariantSnapshot", "Store")';
        var selectedClass = 'is-active';

        function updateVariantState(data) {
            var qtyInput = document.getElementById('orderQuantity');
            var statusNode = document.getElementById('variantStatus');
            var priceNode = document.getElementById('productPrice');
            var addBtn = document.getElementById('addToCartBtn');
            var buyBtn = document.getElementById('buyNowBtn');
            var cartVariant = document.getElementById('cartVariantId');
            var buyVariant = document.getElementById('buyNowVariantId');
            var buyQuantity = document.getElementById('buyNowQuantity');

            if (!data || !data.success) {
                if (statusNode) {
                    statusNode.textContent = data && data.message ? data.message : 'Kh\u00F4ng th\u1EC3 l\u1EA5y th\u00F4ng tin bi\u1EBFn th\u1EC3.';
                }
                return;
            }

            if (statusNode) {
                statusNode.textContent = data.statusText;
            }
            if (priceNode) {
                priceNode.textContent = data.priceText;
            }
            if (cartVariant) {
                cartVariant.value = data.variantId;
            }
            if (buyVariant) {
                buyVariant.value = data.variantId;
            }
            if (qtyInput) {
                qtyInput.max = data.stock > 0 ? data.stock : 1;
                if (parseInt(qtyInput.value || '1', 10) > data.stock && data.stock > 0) {
                    qtyInput.value = data.stock;
                }
                if (parseInt(qtyInput.value || '1', 10) < 1) {
                    qtyInput.value = 1;
                }
            }
            if (buyQuantity && qtyInput) {
                buyQuantity.value = qtyInput.value;
            }
            if (addBtn) {
                addBtn.disabled = !data.inStock;
            }
            if (buyBtn) {
                buyBtn.disabled = !data.inStock;
            }
        }

        function setActiveButton(button) {
            var buttons = document.querySelectorAll('.variant-btn');
            for (var i = 0; i < buttons.length; i++) {
                buttons[i].classList.remove(selectedClass);
            }
            button.classList.add(selectedClass);
        }

        function bindVariantButtons() {
            var buttons = document.querySelectorAll('.variant-btn');
            for (var i = 0; i < buttons.length; i++) {
                buttons[i].addEventListener('click', function () {
                    var btn = this;
                    setActiveButton(btn);
                    var variantId = btn.getAttribute('data-variant-id');

                    $.getJSON(endpoint, { slug: detailsSlug, variantId: variantId })
                        .done(function (resp) {
                            updateVariantState(resp);
                        })
                        .fail(function () {
                            updateVariantState({ success: false, message: 'Kh\u00F4ng c\u1EADp nh\u1EADt \u0111\u01B0\u1EE3c t\u1ED3n kho realtime.' });
                        });
                });
            }
        }

        function bindGalleryThumbs() {
            var mainImage = document.getElementById('mainProductImage');
            if (!mainImage) {
                return;
            }
            var thumbs = document.querySelectorAll('.product-thumb-btn');
            for (var i = 0; i < thumbs.length; i++) {
                thumbs[i].addEventListener('click', function () {
                    mainImage.src = this.getAttribute('data-image-url');
                    mainImage.alt = this.getAttribute('data-image-alt') || mainImage.alt;
                });
            }
        }

        var qtyInput = document.getElementById('orderQuantity');
        var buyQuantity = document.getElementById('buyNowQuantity');
        if (qtyInput && buyQuantity) {
            qtyInput.addEventListener('change', function () {
                buyQuantity.value = qtyInput.value;
            });
        }

        bindVariantButtons();
        bindGalleryThumbs();
    })();
</script>
}

