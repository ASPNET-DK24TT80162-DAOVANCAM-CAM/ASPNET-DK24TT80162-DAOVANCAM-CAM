@model IEnumerable<ShopManagement.Models.Product>

@{
    ViewBag.Title = "Trang Ban Hang";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 mb-1">Trang ban hang</h1>
        <p class="text-muted mb-0">Hien thi toan bo san pham va dat hang nhanh.</p>
    </div>
    @if (!Request.IsAuthenticated)
    {
        @Html.ActionLink("Dang nhap de dat hang", "Login", "Account", null, new { @class = "btn btn-outline-dark" })
    }
</div>

<div class="row g-3">
    @foreach (var item in Model)
    {
        var variants = item.Variants.Where(variant => variant.IsActive && variant.StockQuantity > 0)
            .OrderBy(variant => variant.Color.Name)
            .ThenBy(variant => variant.Size.SortOrder)
            .ToList();

        <div class="col-md-6 col-xl-4">
            <div class="card product-card h-100 border-0">
                <img src="@item.ThumbnailImage" class="card-img-top product-img" alt="@item.Name" />
                <div class="card-body d-flex flex-column">
                    <p class="small text-muted mb-1">@item.Brand.Name • @item.Category.Name</p>
                    <h2 class="h5 mb-2">@item.Name</h2>
                    <p class="small text-muted mb-3">@item.ShortDescription</p>
                    <p class="mb-3 fw-semibold">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VND</p>

                    @if (variants.Any())
                    {
                        using (Html.BeginForm("Add", "Cart", FormMethod.Post, new { @class = "d-grid gap-2 mt-auto" }))
                        {
                            @Html.AntiForgeryToken()
                            <select name="productVariantId" class="form-select form-select-sm">
                                @foreach (var variant in variants)
                                {
                                    <option value="@variant.Id">@variant.Color.Name / Size @variant.Size.Name (Con @variant.StockQuantity)</option>
                                }
                            </select>
                            <input name="quantity" type="number" class="form-control form-control-sm" min="1" value="1" />
                            @Html.Hidden("returnUrl", Request.RawUrl)
                            <button type="submit" class="btn btn-outline-dark btn-sm">Them vao gio</button>
                        }

                        using (Html.BeginForm("BuyNow", "Cart", FormMethod.Post, new { @class = "d-grid mt-2" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("productVariantId", variants.First().Id)
                            @Html.Hidden("quantity", 1)
                            <button type="submit" class="btn btn-dark btn-sm">Dat hang ngay</button>
                        }
                    }
                    else
                    {
                        <span class="badge text-bg-secondary mt-auto">Het hang</span>
                    }
                </div>
            </div>
        </div>
    }
</div>