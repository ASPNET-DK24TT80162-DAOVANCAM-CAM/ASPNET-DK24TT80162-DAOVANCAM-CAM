@model ShopManagement.Models.Product

@{
    ViewBag.Title = "Bi\u1EBFn th\u1EC3 s\u1EA3n ph\u1EA9m";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 mb-1">Biến thể và tồn kho</h1>
        <p class="text-muted mb-0">@Model.Name (@Model.Sku)</p>
    </div>
    <a href="@Url.Action("Index", "AdminProducts")" class="btn btn-outline-dark">Về danh sách sản phẩm</a>
</div>

<div class="card form-card p-3 mb-3">
    <h2 class="h6 mb-3">Thêm biến thể</h2>
    @using (Html.BeginForm("AddVariant", "AdminProducts", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("productId", Model.Id)
        <div class="row g-2">
            <div class="col-md-2">@Html.DropDownList("colorId", (SelectList)ViewBag.ColorId, new { @class = "form-select" })</div>
            <div class="col-md-2">@Html.DropDownList("sizeId", (SelectList)ViewBag.SizeId, new { @class = "form-select" })</div>
            <div class="col-md-2"><input name="sku" class="form-control" placeholder="SKU" required /></div>
            <div class="col-md-2"><input name="price" type="number" min="0" step="1000" class="form-control" placeholder="Giá" required /></div>
            <div class="col-md-2"><input name="stockQuantity" type="number" min="0" class="form-control" placeholder="Tồn kho" required /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-dark" type="submit">Thêm</button></div>
        </div>
    }
</div>

<div class="card dashboard-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>SKU</th>
                        <th>Màu</th>
                        <th>Size</th>
                        <th>Giá</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Variants.OrderBy(v => v.Color.Name).ThenBy(v => v.Size.SortOrder))
                    {
                        <tr>
                            <td>@item.Sku</td>
                            <td>@item.Color.Name</td>
                            <td>@item.Size.Name</td>
                            <td>
                                @using (Html.BeginForm("UpdateVariant", "AdminProducts", FormMethod.Post, new { @class = "d-flex gap-2" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.Id)
                                    <input name="price" type="number" min="0" step="1000" class="form-control form-control-sm" value="@item.Price" style="max-width:130px" />
                                    <input name="stockQuantity" type="number" min="0" class="form-control form-control-sm" value="@item.StockQuantity" style="max-width:90px" />
                                    <div class="form-check mt-1">
                                        <input class="form-check-input" type="checkbox" name="isActive" value="true" @(item.IsActive ? "checked" : "") />
                                    </div>
                                    <button class="btn btn-sm btn-outline-dark" type="submit">Lưu</button>
                                }
                            </td>
                            <td>@item.StockQuantity</td>
                            <td><span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "B\u1EADt" : "T\u1EAFt")</span></td>
                            <td class="text-end">
                                @using (Html.BeginForm("DeleteVariant", "AdminProducts", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.Id)
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
