@model IEnumerable<ShopManagement.Models.Order>

@{
    ViewBag.Title = "\u0110\u01A1n h\u00E0ng c\u1EE7a t\u00F4i";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
}

<div class="page-header">
    <h1 class="h3 mb-1">Đơn hàng của tôi</h1>
    <p class="text-muted mb-0">Theo dõi lịch sử và chi tiết đơn hàng.</p>
</div>

<div class="card dashboard-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Trạng thái</th>
                        <th>Tổng tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderCode</td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge text-bg-secondary">@order.OrderStatus</span></td>
                            <td>@order.TotalAmount.ToString("N0") VNĐ</td>
                            <td><a href="@Url.Action("Details", "Orders", new { id = order.Id })" class="btn btn-sm btn-outline-dark">Xem</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
