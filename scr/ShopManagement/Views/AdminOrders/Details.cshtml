@model ShopManagement.Models.Order

@{
    ViewBag.Title = "Chi ti\u1EBFt \u0111\u01A1n h\u00E0ng";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 mb-1">@Model.OrderCode</h1>
        <p class="text-muted mb-0">@Model.ReceiverName • @Model.PhoneNumber</p>
    </div>
    <a href="@Url.Action("Index", "AdminOrders")" class="btn btn-outline-dark">Quay lại</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card dashboard-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Biến thể</th>
                                <th>Qty</th>
                                <th>Đơn giá</th>
                                <th>Tổng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.ColorName / @item.SizeName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("N0")</td>
                                    <td>@item.LineTotal.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card form-card p-4">
            <h2 class="h6 mb-3">Cập nhật trạng thái</h2>
            @using (Html.BeginForm("UpdateStatus", "AdminOrders", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("id", Model.Id)
                @Html.DropDownList("orderStatus", (SelectList)ViewBag.StatusOptions, new { @class = "form-select mb-3" })
                <button type="submit" class="btn btn-dark w-100">Lưu trạng thái</button>
            }
            <hr />
            <p class="mb-1">Tạm tính: <strong>@Model.Subtotal.ToString("N0")</strong></p>
            <p class="mb-1">Phí vận chuyển: <strong>@Model.ShippingFee.ToString("N0")</strong></p>
            <p class="mb-0">Tổng: <strong>@Model.TotalAmount.ToString("N0") VNĐ</strong></p>
        </div>
    </div>
</div>

