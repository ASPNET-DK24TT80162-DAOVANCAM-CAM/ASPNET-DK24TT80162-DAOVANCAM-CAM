@model IEnumerable<ShopManagement.Models.AppUser>

@{
    ViewBag.Title = "Qu\u1EA3n l\u00FD ng\u01B0\u1EDDi d\u00F9ng";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
    <div>
        <h1 class="h3 mb-1">Quản lý người dùng</h1>
        <p class="text-muted mb-0">Quản lý thông tin tài khoản và phân quyền Admin, Manager hoặc Customer.</p>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-center">
        @if (User.IsInRole("Admin"))
        {
            <span class="badge text-bg-warning text-dark">Được phép cập nhật quyền</span>
            <a href="@Url.Action("Create", "UserAdmin")" class="btn btn-dark btn-sm">Thêm người dùng</a>
        }
        else
        {
            <span class="badge text-bg-secondary">Manager chỉ có quyền xem</span>
        }
    </div>
</div>

<div class="card dashboard-card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-4 text-center">
                <h2 class="h5 mb-2">Chưa có người dùng nào</h2>
                <p class="text-muted mb-0">Danh sách người dùng sẽ hiển thị tại đây sau khi tạo tài khoản.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Điện thoại</th>
                            <th>CCCD</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.CitizenId</td>
                                <td>
                                    <span class="badge role-badge @(item.Role.Name == "Admin" ? "text-bg-dark" : item.Role.Name == "Manager" ? "text-bg-primary" : "text-bg-success")">@item.Role.Name</span>
                                </td>
                                <td>
                                    <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-danger")">@(item.IsActive ? "Đang hoạt động" : "Đã khóa")</span>
                                </td>
                                <td class="text-end">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="d-flex justify-content-end gap-2">
                                            @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-dark" })
                                            using (@Html.BeginForm("ToggleActive", "UserAdmin", FormMethod.Post, new { @class = "d-inline-block" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                @Html.Hidden("id", item.Id)
                                                <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-danger" : "btn-outline-success")">@(item.IsActive ? "Khóa" : "Mở khóa")</button>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

