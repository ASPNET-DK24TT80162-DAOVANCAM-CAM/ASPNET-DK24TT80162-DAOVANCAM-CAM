@model ShopManagement.Models.StoreHomeViewModel
@using System.Linq

@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_ShopLayout.cshtml";
    var heroProduct = Model.NewArrivals.FirstOrDefault();
    var menTile = Model.FeaturedMen.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ThumbnailImage))
                 ?? Model.NewArrivals.FirstOrDefault(item => (item.Gender == "Men" || item.Gender == "Unisex") && !string.IsNullOrWhiteSpace(item.ThumbnailImage));
    var womenTile = Model.FeaturedWomen.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ThumbnailImage))
                   ?? Model.NewArrivals.FirstOrDefault(item => (item.Gender == "Women" || item.Gender == "Unisex") && !string.IsNullOrWhiteSpace(item.ThumbnailImage));
    var unisexTile = Model.NewArrivals.FirstOrDefault(item => item.Gender == "Unisex" && !string.IsNullOrWhiteSpace(item.ThumbnailImage))
                    ?? Model.NewArrivals.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ThumbnailImage));
    var bestSellerTile = Model.NewArrivals.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ThumbnailImage));
}

    <section class="hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="eyebrow">Bộ sưu tập Thu Đông 2026</div>
                    <h1>Bước êm, đi chất mỗi ngày.</h1>
                    <p>Giày chính hãng từ các thương hiệu uy tín. Form hợp chân Việt, đổi size dễ dàng trong 30 ngày và giao nhanh trên toàn quốc.</p>
                    <div class="d-flex gap-2 mt-4">
                        <a href="@Url.Action("Products", "Store")" class="btn btn-dark px-4">Mua ngay</a>
                        <a href="@Url.Action("Products", "Store")" class="btn btn-outline-dark px-4">Xem ưu đãi</a>
                    </div>
                </div>
                <div class="col-lg-6">
                    @if (heroProduct != null && !string.IsNullOrWhiteSpace(heroProduct.ThumbnailImage))
                    {
                        <a href="@Url.Action("Details", "Store", new { slug = heroProduct.Slug })" class="d-block text-decoration-none">
                            <img src="@heroProduct.ThumbnailImage" alt="@heroProduct.Name" class="img-fluid rounded-4 shadow-sm" />
                        </a>
                    }
                    else
                    {
                        <div class="hero-visual">[ Hình ảnh sản phẩm nổi bật ]</div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="section-head">
                <h2>Mua theo danh mục</h2>
                <a href="@Url.Action("Products", "Store")" class="small">Xem tất cả -></a>
            </div>
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <a class="cat-tile" href="@Url.Action("Products", "Store", new { gender = "Men" })">
                        @if (menTile != null)
                        {
                            <img src="@menTile.ThumbnailImage" class="cat-tile-media" alt="Giày nam" />
                        }
                        <span class="cat-tile-label">Nam</span>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="cat-tile" href="@Url.Action("Products", "Store", new { gender = "Women" })">
                        @if (womenTile != null)
                        {
                            <img src="@womenTile.ThumbnailImage" class="cat-tile-media" alt="Giày nữ" />
                        }
                        <span class="cat-tile-label">Nữ</span>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="cat-tile" href="@Url.Action("Products", "Store", new { gender = "Unisex" })">
                        @if (unisexTile != null)
                        {
                            <img src="@unisexTile.ThumbnailImage" class="cat-tile-media" alt="Giày unisex" />
                        }
                        <span class="cat-tile-label">Unisex</span>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="cat-tile" href="@Url.Action("Products", "Store", new { sort = "best_selling" })">
                        @if (bestSellerTile != null)
                        {
                            <img src="@bestSellerTile.ThumbnailImage" class="cat-tile-media" alt="Giày bán chạy" />
                        }
                        <span class="cat-tile-label">Bán chạy</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="section pt-0">
        <div class="container">
            <div class="section-head">
                <h2>Sản phẩm mới</h2>
                <a href="@Url.Action("Products", "Store")" class="small">Tất cả sản phẩm mới -></a>
            </div>
            <div class="row g-4">
                @foreach (var item in Model.NewArrivals.Take(4))
                {
                    <div class="col-6 col-md-3">
                        <a class="product-card d-block" href="@Url.Action("Products", "Store", new { gender = item.Gender, category = item.CategoryId, brand = item.BrandId })">
                            <img src="@item.ThumbnailImage" class="w-100 rounded-3 mb-2" alt="@item.Name" />
                            <div class="body">
                                <div class="brand">@item.Brand.Name</div>
                                <div class="name">@item.Name</div>
                                <div class="price">@((item.SalePrice ?? item.BasePrice).ToString("N0")) VNĐ</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="usp">
        <div class="container">
            <div class="row">
                <div class="col-6 col-md-3 item"><div class="t">100% Chính Hãng</div><div class="d">Cam kết sản phẩm chính hãng</div></div>
                <div class="col-6 col-md-3 item"><div class="t">Giao Hàng Nhanh</div><div class="d">Giao nhanh tại các thành phố lớn</div></div>
                <div class="col-6 col-md-3 item"><div class="t">Đổi Size 30 Ngày</div><div class="d">Hỗ trợ đổi size miễn phí</div></div>
                <div class="col-6 col-md-3 item"><div class="t">Bảo Hành</div><div class="d">Hỗ trợ lỗi nhà sản xuất</div></div>
            </div>
        </div>
    </section>

